# Path to local SQLite database file (defaults to ./data.db)
DATABASE_URL=./data.db

# Secret used to sign JWT session cookies. Use a long, random value in production.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string

# Optional. Enables the AI assistant. Get a key at https://vercel.com/ai-gateway
# Without this set, the assistant runs in offline demo mode.
AI_GATEWAY_API_KEY=
